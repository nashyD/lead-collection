# Copy this file to .env.local for local dev, or set these in Vercel Project Settings → Environment Variables.
# The form and dashboard each tolerate missing vars: if Supabase is unset the form still
# emails/texts (just doesn't persist); if email/SMS are unset leads still land in the DB.
# Add them progressively as Anthony sets up each service.

# --- Supabase (lead persistence + dashboard backing store) ---
# Get these from Supabase Dashboard → Project Settings → API.
# SUPABASE_SERVICE_ROLE_KEY is SERVER-ONLY. Never expose it to the browser.
SUPABASE_URL=                     # e.g. https://abcd1234.supabase.co
SUPABASE_SERVICE_ROLE_KEY=        # service_role secret (NOT the anon key)

# --- Dashboard (lead-tracking UI at /dashboard) ---
# DASHBOARD_PASSWORD is what Anthony types to sign in.
# DASHBOARD_SESSION_SECRET signs the auth cookie — make it long & random.
#   Generate one with: openssl rand -hex 32
DASHBOARD_PASSWORD=
DASHBOARD_SESSION_SECRET=

# --- Email notification to Anthony (via Resend.com — free tier: 3,000/mo) ---
RESEND_API_KEY=
ANTHONY_EMAIL=
FROM_EMAIL=leads@yourdomain.com   # must be a domain you verified in Resend

# --- SMS notification to Anthony (via Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=               # e.g. +17045550100, must be a Twilio number you own
ANTHONY_PHONE=                    # e.g. +17048538001 in E.164 format

# --- Auto-text the lead immediately on submit ---
# Set to "true" to send a "Anthony will text you in 5 min" confirmation SMS to the lead.
# Requires the Twilio vars above. Be sure you have TCPA-compliant consent language on the form
# (we do — see fine print under the submit button).
SEND_LEAD_CONFIRMATION=false
