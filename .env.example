# Copy this file to .env.local for local dev, or set these in Vercel Project Settings → Environment Variables.
# Everything is fail-soft: if Supabase is unset the form still tries to email; if Resend is
# unset, leads still save to the database. Add each as you set up the service.

# --- Supabase (lead storage + dashboard + notification recipient list) ---
# Supabase Dashboard → Project Settings → API.
# SUPABASE_SERVICE_ROLE_KEY is SERVER-ONLY. Never expose it to the browser.
SUPABASE_URL=                     # e.g. https://abcd1234.supabase.co
SUPABASE_SERVICE_ROLE_KEY=        # the secret / service_role key (NOT publishable/anon)

# --- Dashboard (lead board at /dashboard) ---
# DASHBOARD_PASSWORD is what the office types to sign in.
# DASHBOARD_SESSION_SECRET signs the auth cookie — make it long & random.
#   Generate one with: openssl rand -hex 32
DASHBOARD_PASSWORD=
DASHBOARD_SESSION_SECRET=

# --- Email (Resend — free tier: 3,000/mo, 100/day) ---
# Powers BOTH the lead's confirmation email and the office notification emails.
# FROM_EMAIL must be on a domain you've verified in Resend; without a verified domain,
# Resend only lets you send from its onboarding@resend.dev sandbox (fine for testing).
# Office notification recipients are managed in the dashboard Settings panel, not here.
RESEND_API_KEY=
FROM_EMAIL=leads@yourdomain.com   # e.g. leads@gallantrenters.com (must be verified in Resend)

# --- Bot protection (Cloudflare Turnstile — free) ---
# Create a widget at dash.cloudflare.com → Turnstile. You get two keys:
#   TURNSTILE_SITE_KEY    is PUBLIC — it ships to the browser (served via /api/config).
#   TURNSTILE_SECRET_KEY  is SERVER-ONLY — /api/lead uses it to verify each submission.
# Until BOTH are set the form still works but is UNPROTECTED. Set both before launch.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Analytics: Meta (Facebook) Pixel ---
# Powers conversion tracking for the Facebook ad campaigns (PageView on every
# visit + a "Lead" event on each successful submit) so you can measure
# cost-per-lead and let Meta optimize delivery. The Pixel ID is PUBLIC (it ships
# in the page). Find it in Meta Events Manager → Data Sources → your pixel.
# Left unset, no pixel loads and the pages work exactly as before.
META_PIXEL_ID=

# Meta Conversions API (server-side — optional but recommended). A SERVER-ONLY
# token that lets /api/lead send the Lead conversion to Meta directly, recovering
# events lost to iOS/ad-blockers. Deduped with the browser pixel via a shared
# event_id, so the conversion is still counted once. Generate in Meta Events
# Manager → your pixel → Settings → Conversions API → Generate access token.
# KEEP SECRET (never served to the browser). Needs META_PIXEL_ID set too. Unset = no-op.
META_CAPI_TOKEN=

# --- Analytics: Google (GA4 + Google Ads) ---
# Optional second measurement channel, mirroring the Meta pixel. All three are
# PUBLIC (they ship in the page via /api/config) and dormant until set — no tag
# loads and the pages behave exactly as before. On a successful submit the page
# fires a GA4 `generate_lead` event and, when the Ads conversion is set, a Google
# Ads `conversion`. No PII is ever sent.
#   GA4_MEASUREMENT_ID          GA4 → Admin → Data Streams → your stream (e.g. G-XXXXXXX)
#   GOOGLE_ADS_CONVERSION_ID    Google Ads → Goals → Conversions → your action (e.g. AW-XXXXXXXXX)
#   GOOGLE_ADS_CONVERSION_LABEL the label paired with that conversion action (the part after the '/')
GA4_MEASUREMENT_ID=
GOOGLE_ADS_CONVERSION_ID=
GOOGLE_ADS_CONVERSION_LABEL=

# --- Deliverability (DNS records — NOT env vars; set these at your DNS provider) ---
# SPF + DKIM are already configured for Resend. The remaining piece is DMARC,
# which helps the confirmation emails land in the inbox instead of spam:
#   Type: TXT   Name: _dmarc   Value: v=DMARC1; p=none; rua=mailto:dmarc@gallantrenters.com
# Start with p=none (monitor only); tighten to p=quarantine once reports look clean.
